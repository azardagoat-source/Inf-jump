-- Modular Component Factory Function
local function CompileButton(name, defaultText, positionY)
	local NewButton = Instance.new("TextButton")
	NewButton.Name = name .. "Control"
	NewButton.Size = UDim2.new(0, 240, 0, 35)
	NewButton.Position = UDim2.new(0, 20, 0, positionY)
	NewButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
	NewButton.Text = defaultText
	NewButton.TextColor3 = Color3.fromRGB(230, 230, 230)
	NewButton.Font = Enum.Font.SourceSansSemibold
	NewButton.TextSize = 13
	NewButton.Parent = BasePanel
	
	local BtnCorner = Instance.new("UICorner")
	BtnCorner.CornerRadius = UDim.new(0, 4)
	BtnCorner.Parent = NewButton
	
	local BtnStroke = Instance.new("UIStroke")
	BtnStroke.Color = Color3.fromRGB(55, 55, 60)
	BtnStroke.Thickness = 1
	BtnStroke.Parent = NewButton
	
	return NewButton
end

