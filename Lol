-- // 4. INTERACTION EVENT WIREUP
local function UpdateButtonVisual(buttonObject, condition, trueText, falseText)
	if condition then
		buttonObject.Text = trueText
		buttonObject.BackgroundColor3 = Color3.fromRGB(0, 145, 90)
	else
		buttonObject.Text = falseText
		buttonObject.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
	end
end

MasterToggleBtn.MouseButton1Click:Connect(function()
	SystemsConfig.MasterActive = not SystemsConfig.MasterActive
	UpdateButtonVisual(MasterToggleBtn, SystemsConfig.MasterActive, "MASTER CORE: ENABLED", "MASTER CORE: DISABLED")
end)

TargetLockBtn.MouseButton1Click:Connect(function()
