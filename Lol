-- // 5. MATHEMATICAL TARGET SELECTION FUNCTION
local function ScanForNearestTargetPart()
	local localCharacter = LocalPlayer.Character
	if not localCharacter or not localCharacter:FindFirstChild("HumanoidRootPart") then return nil end
	
	local closestPart = nil
	local shortestDistance = SystemsConfig.TrackingRange
	local originPosition = localCharacter.HumanoidRootPart.Position

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local characterModel = player.Character
			local humanoid = characterModel:FindFirstChildOfClass("Humanoid")
			local bonePart = characterModel:FindFirstChild(SystemsConfig.TargetBone) or characterModel:FindFirstChild("HumanoidRootPart")
			
			if bonePart and humanoid and humanoid.Health > 0 then
				local currentDistance = (bonePart.Position - originPosition).Magnitude
				if currentDistance < shortestDistance then
					shortestDistance = currentDistance
					closestPart = bonePart
				end
			end
		end
	end
	return closestPart
end

-- // 6. FRAME CYCLE COMPUTATION LOOP
RunService.RenderStepped:Connect(function()
	Camera = Workspace.CurrentCamera
	
	-- Only pass math vectors if both the overall engine frame and individual parameters are active
	if not SystemsConfig.MasterActive then return end
	
	local validTarget = ScanForNearestTargetPart()
	
	if validTarget and Camera then
		-- Process camera frame adjustments standardly if TargetLock or AimMode options are verified
		if SystemsConfig.TargetLockActive or SystemsConfig.AimModeActive then
			local lookAngle = CFrame.lookAt(Camera.CFrame.Position, validTarget.Position)
			Camera.CFrame = Camera.CFrame:Lerp(lookAngle, SystemsConfig.CameraSmoothness)
		end
	end
end)

